{
  "output_dir": "output/enhanced_training",
  "data_dir": "data/processed",
  "train_file": "merged_train.jsonl",
  "dev_file": "merged_dev.jsonl",
  "hidden_size": 256,
  "num_hidden_layers": 4,
  "num_attention_heads": 4,
